<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button android:id="@+id/btnGrantOverlay" android:layout_width="match_parent" android:layout_height="64dp" android:text="开启悬浮窗权限"/>
        <Button android:id="@+id/btnGrantBattery" android:layout_width="match_parent" android:layout_height="64dp" android:text="忽略电池优化"/>
        <Button android:id="@+id/btnStartService" android:layout_width="match_parent" android:layout_height="64dp" android:text="启动后台服务"/>
        <Button android:id="@+id/btnExecMain" android:layout_width="match_parent" android:layout_height="64dp" android:text="立即执行 主屏列表"/>
        <Button android:id="@+id/btnExecSub" android:layout_width="match_parent" android:layout_height="64dp" android:text="立即执行 副屏列表"/>
        <Button android:id="@+id/btnExport" android:layout_width="match_parent" android:layout_height="64dp" android:text="导出配置"/>
        <Button android:id="@+id/btnImport" android:layout_width="match_parent" android:layout_height="64dp" android:text="导入配置"/>

    </LinearLayout>
</ScrollView>
